# DocAnchor Backend Configuration
# Copy this to .env and adjust as needed

# Set to False to wire real integrations (LLM key, GitHub token required)
USE_MOCKS=True

# Server
HOST=0.0.0.0
PORT=8000

# Qdrant – uses in-memory mode by default (no external service needed)
QDRANT_IN_MEMORY=True
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Mock GitHub repo used for demo mode (no token needed)
MOCK_GITHUB_REPO=acme/sample-app

# Real LLM integration (optional). Leave blank to use mock LLM rewrites.
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# Real GitHub integration (optional). Leave blank to use mock PR creation.
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com
WEBHOOK_SECRET=

# Slack webhook for drift alerts (optional)
SLACK_WEBHOOK_URL=

# LLM latency simulation (seconds)
MOCK_LLM_DELAY=0.4